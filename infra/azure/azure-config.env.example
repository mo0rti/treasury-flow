# =============================================================================
# TreasuryFlow - Azure Infrastructure Configuration
# =============================================================================
# Copy this file to azure-config.env and fill in your values.
# NEVER commit azure-config.env to version control.

# Project
PROJECT_NAME="treasuryflow"
ENVIRONMENT="prod"       # prod | acc | dev
LOCATION="westeurope"    # Azure region

# Azure Subscription
AZURE_SUBSCRIPTION_ID="your-subscription-id"

# Resource Group
RESOURCE_GROUP="${PROJECT_NAME}-${ENVIRONMENT}-rg"

# Container Registry
ACR_NAME="${PROJECT_NAME//[-_]/}acr"    # Must be globally unique, alphanumeric only
ACR_SKU="Basic"                         # Basic ($5/mo), Standard, Premium

# Log Analytics
LOG_ANALYTICS_NAME="${PROJECT_NAME}-${ENVIRONMENT}-logs"

# PostgreSQL
POSTGRES_SERVER_NAME="${PROJECT_NAME}-${ENVIRONMENT}-db"   # Must be globally unique
POSTGRES_ADMIN_USER="${PROJECT_NAME//[-]/_}_admin"
POSTGRES_ADMIN_PASSWORD=""              # Auto-generated if empty (32 chars)
POSTGRES_DATABASE_NAME="treasuryflow"
POSTGRES_SKU="Standard_B1ms"           # Burstable tier (~$12-25/mo)
POSTGRES_STORAGE_SIZE_GB="32"
POSTGRES_VERSION="16"

# Optional Redis cache


# Container Apps Environment
CONTAINER_APPS_ENV_NAME="${PROJECT_NAME}-${ENVIRONMENT}-env"

# Backend Container App
BACKEND_APP_NAME="${PROJECT_NAME}-backend"
BACKEND_MIN_REPLICAS="1"
BACKEND_MAX_REPLICAS="3"
BACKEND_CPU="0.5"
BACKEND_MEMORY="1.0Gi"

# Storage Account
STORAGE_ACCOUNT_NAME="${PROJECT_NAME//[-_]/}storage"   # Must be globally unique, alphanumeric only

# Frontend origins allowed by backend CORS
CORS_ALLOWED_ORIGINS="https://app.treasuryflow.com,https://admin.treasuryflow.com"

