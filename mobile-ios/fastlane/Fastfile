default_platform(:ios)

platform :ios do
  desc "Run tests"
  lane :test do
    run_tests(
      project: "TreasuryFlow.xcodeproj",
      scheme: "Treasuryflow",
      device: "iPhone 16",
      clean: true,
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    match(
      type: "appstore",
      readonly: is_ci,
      api_key: api_key,
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || (latest_testflight_build_number + 1).to_s,
    )

    build_app(
      project: "TreasuryFlow.xcodeproj",
      scheme: "Treasuryflow",
      export_method: "app-store",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
