<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#EEF7FF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item android:gravity="top|left" android:left="28dp" android:top="40dp">
        <shape android:shape="oval">
            <size android:width="80dp" android:height="80dp" />
            <solid android:color="#CBE8FF" />
        </shape>
    </item>
    <item android:gravity="top|right" android:right="24dp" android:top="62dp">
        <shape android:shape="oval">
            <size android:width="110dp" android:height="110dp" />
            <solid android:color="#B6DAFF" />
        </shape>
    </item>
    <item android:gravity="center" android:left="28dp" android:right="28dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|bottom" android:bottom="68dp">
        <shape android:shape="rectangle">
            <size android:width="210dp" android:height="14dp" />
            <corners android:radius="999dp" />
            <solid android:color="#D0E4F7" />
        </shape>
    </item>
    <item android:gravity="center" android:width="150dp" android:height="150dp" android:drawable="@drawable/ic_brand_logo" />
</layer-list>
