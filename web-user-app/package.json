{
  "name": "treasuryflow-web-user-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['.next','.open-next'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\"",
    "build:cloudflare": "npm run clean && opennextjs-cloudflare build",
    "preview": "npm run build:cloudflare && opennextjs-cloudflare preview",
    "deploy": "npm run build:cloudflare && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.35",
    "next-auth": "5.0.0-beta.29",
    "next-intl": "4.5.8",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.15.1",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "wrangler": "4.77.0"
  }
}
